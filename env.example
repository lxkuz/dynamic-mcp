# Скопируйте в .env: cp env.example .env

SECRET_KEY_BASE=generate-with-bin-rails-secret
RAILS_LOG_LEVEL=info
WEB_PORT=3020
PUBLIC_HOST=localhost
PUBLIC_SCHEME=http
MCP_ALLOWED_ORIGINS=localhost,127.0.0.1
ELASTICSEARCH_URL=http://elasticsearch:9200

# Sidekiq + AI import
REDIS_URL=redis://redis:6379/0
AI_IMPORT_ENABLED=true
DEEPSEEK_API_KEY=
PARSER_SANDBOX_IMAGE=dynamic-mcp-parser-sandbox:latest

# На демо-стенде: абсолютный путь на хосте для docker mount sandbox
# BOOK_IMPORT_HOST_WORKDIR=/home/dockeruser/bookworm/tmp/book-import

# --- Deploy (локальный .env для ./deploy.sh) ---
DEPLOY_SERVER=dockeruser@159.194.203.146
DEPLOY_PATH=/home/dockeruser/bookworm
DEPLOY_BRANCH=main
# Путь к ключу на СЕРВЕРЕ (для git pull по SSH из deploy.sh)
DEPLOY_GIT_SSH_KEY=/home/dockeruser/.ssh/github_bookworm_deploy

# Nginx + Let's Encrypt (script/setup-nginx.sh на сервере)
BOOKWORM_DOMAIN=bookworm.breget.tech
BOOKWORM_LETSENCRYPT_EMAIL=you@example.com
# На сервере после nginx: PUBLIC_HOST=bookworm.breget.tech, PUBLIC_SCHEME=https
