# Скопируйте в .env: cp env.example .env

SECRET_KEY_BASE=generate-with-bin-rails-secret
RAILS_LOG_LEVEL=info
WEB_PORT=3020
PUBLIC_HOST=localhost
PUBLIC_SCHEME=http
WEB_PORT=3020
MCP_ALLOWED_ORIGINS=localhost,127.0.0.1
ELASTICSEARCH_URL=http://elasticsearch:9200

# Sidekiq + AI import
REDIS_URL=redis://redis:6379/0
AI_IMPORT_ENABLED=true
DEEPSEEK_API_KEY=
PARSER_SANDBOX_IMAGE=dynamic-mcp-parser-sandbox:latest

DEPLOY_TARGET=production
DEPLOY_SERVER_PRODUCTION=dockeruser@your-host
DEPLOY_PATH_PRODUCTION=dynamic-mcp
DEPLOY_GIT_BRANCH_PRODUCTION=main
DEPLOY_SERVER_STAGING=dockeruser@staging-host
DEPLOY_PATH_STAGING=dynamic-mcp_staging
DEPLOY_GIT_BRANCH_STAGING=develop
