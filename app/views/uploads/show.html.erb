<% unless @book.ready? || @book.status == "failed" %>
<script>
(function() {
  const STATUS_ORDER = <%= Books::Import::Progress::STATUS_ORDER.to_json.html_safe %>;
  const LOOP_KEYS = <%= Books::Import::Progress::LOOP_PHASES.map { |p| p[:key] }.to_json.html_safe %>;
  const INITIAL = <%= (@import_progress || {}).to_json.html_safe %>;

  const seenEvents = new Set();
  let activeScriptKey = null;

  const SCRIPT_STATE_LABELS = {
    writing: "AI генерирует код…",
    validating: "Статическая проверка…",
    running: "Sandbox выполняет скрипт…",
    error: "Есть ошибки — будет исправление",
    ok: "Скрипт прошёл все проверки",
    pending: "Ожидание…"
  };

  const SCRIPT_BADGE_LABELS = {
    writing: "пишется",
    validating: "проверка",
    running: "запуск",
    error: "ошибка",
    ok: "ок",
    pending: "…"
  };

  function phaseIndex(status) {
    const idx = STATUS_ORDER.indexOf(status);
    return idx >= 0 ? idx : 0;
  }

  function formatTime(iso) {
    if (!iso) return "—";
    const d = new Date(iso);
    return d.toLocaleTimeString("ru-RU", { hour: "2-digit", minute: "2-digit", second: "2-digit" });
  }

  function headlineFor(status) {
    const map = {
      queued: "Ожидание в очереди…",
      sampling: "Читаем файл…",
      discovering_toc: "Ищем оглавление…",
      analyzing: "Анализируем структуру…",
      scripting: "AI пишет парсер…",
      validating: "Проверяем скрипт…",
      running: "Запускаем парсер в sandbox…",
      reviewing: "Оцениваем результат…",
      legacy_fallback: "Legacy-парсер (PDF/FB2)…",
      persisting: "Сохраняем книгу…",
      indexing: "Индексируем для поиска…",
      ready: "Готово!"
    };
    return map[status] || "Импорт выполняется…";
  }

  function updateSteps(container, status) {
    if (!container) return;
    const current = phaseIndex(status);
    container.querySelectorAll(".import-step").forEach(function(el) {
      const key = el.dataset.phase;
      const idx = phaseIndex(key);
      el.classList.remove("is-active", "is-done");
      if (idx < current) el.classList.add("is-done");
      else if (key === status) el.classList.add("is-active");
    });
  }

  function updateLoop(status, iteration, maxIterations) {
    const loop = document.getElementById("import-loop");
    const label = document.getElementById("import-iteration-label");
    if (!loop) return;

    const inLoop = LOOP_KEYS.indexOf(status) >= 0;
    loop.classList.toggle("is-active", inLoop);
    if (label) label.textContent = "итерация " + (iteration || 0) + " / " + (maxIterations || 10);

    loop.querySelectorAll(".import-loop-step").forEach(function(el) {
      const key = el.dataset.phase;
      el.classList.remove("is-active", "is-done");
      if (!inLoop) return;
      const keyIdx = LOOP_KEYS.indexOf(key);
      const statusIdx = LOOP_KEYS.indexOf(status);
      if (keyIdx < statusIdx) el.classList.add("is-done");
      else if (key === status) el.classList.add("is-active");
    });
  }

  function updateProgress(status) {
    const fill = document.getElementById("import-progress-fill");
    if (!fill) return;
    const idx = phaseIndex(status);
    const pct = Math.min(100, Math.round((idx / (STATUS_ORDER.length - 1)) * 100));
    fill.style.width = pct + "%";
  }

  function appendEvents(events) {
    const list = document.getElementById("import-log-list");
    if (!list || !events) return;

    events.slice().reverse().forEach(function(ev) {
      if (seenEvents.has(ev.id)) return;
      seenEvents.add(ev.id);

      const li = document.createElement("li");
      li.className = "import-log__item is-" + (ev.status || "info");
      const iter = ev.iteration ? " #" + ev.iteration : "";
      const msg = ev.message ? " — " + ev.message : "";
      li.innerHTML =
        '<span class="import-log__time">' + formatTime(ev.created_at) + '</span>' +
        '<span class="import-log__text">' + (ev.label || ev.step) + iter + msg + '</span>';
      list.prepend(li);
    });

    while (list.children.length > 14) list.removeChild(list.lastChild);
  }

  function buildScriptViews(imp) {
    const views = (imp.script_iterations || []).map(function(item) {
      return {
        key: "hist-" + item.id,
        iteration: item.iteration,
        state: item.state,
        script: item.script,
        errors: item.errors || [],
        unchanged: item.unchanged === true
      };
    });

    const live = imp.script;
    if (live && live.script) {
      const lastHist = views[views.length - 1];
      const duplicate = lastHist &&
        lastHist.iteration === live.iteration &&
        lastHist.script === live.script &&
        lastHist.state === live.state;
      const inProgress = [ "writing", "validating", "running", "reviewing" ].indexOf(live.state) >= 0;
      if (!duplicate || inProgress) {
        views.push({
          key: "live",
          iteration: live.iteration,
          state: live.state,
          script: live.script,
          errors: live.errors || [],
          unchanged: lastHist && lastHist.script === live.script,
          live: true
        });
      }
    }

    return views;
  }

  function renderScript(imp) {
    const panel = document.getElementById("import-script-panel");
    if (!panel) return;

    const views = buildScriptViews(imp);
    if (!views.length) {
      panel.style.display = "none";
      return;
    }

    panel.style.display = "block";

    if (!activeScriptKey || !views.some(function(v) { return v.key === activeScriptKey; })) {
      activeScriptKey = views[views.length - 1].key;
    }

    const current = views.find(function(v) { return v.key === activeScriptKey; }) || views[views.length - 1];
    const state = current.state || "pending";

    panel.className = "import-script-panel is-" + state;

    const badge = document.getElementById("import-script-badge");
    if (badge) {
      badge.className = "import-script-badge is-" + state;
      let badgeText = SCRIPT_BADGE_LABELS[state] || state;
      if (current.unchanged) badgeText += " · без изменений";
      badge.textContent = badgeText;
    }

    const subtitle = document.getElementById("import-script-subtitle");
    if (subtitle) {
      let sub = "итерация " + (current.iteration || "—") + " · " + (SCRIPT_STATE_LABELS[state] || "");
      if (current.errors && current.errors.length && inProgressState(state)) {
        sub = "итерация " + (current.iteration || "—") + " · исправляем ошибки прошлого прогона…";
      } else if (current.unchanged) {
        sub += " · скрипт идентичен прошлой версии";
      }
      subtitle.textContent = sub;
    }

    function inProgressState(s) {
      return [ "writing", "validating", "running" ].indexOf(s) >= 0;
    }

    const code = document.getElementById("import-script-code");
    if (code) {
      const prev = code.textContent;
      const next = current.script || "";
      if (prev !== next) {
        code.textContent = next;
        code.style.animation = "none";
        void code.offsetHeight;
        code.style.animation = "import-log-in 0.35s ease";
        const viewport = document.getElementById("import-script-viewport");
        if (viewport) viewport.scrollTop = 0;
      }
    }

    const errorsEl = document.getElementById("import-script-errors");
    if (errorsEl) {
      errorsEl.innerHTML = "";
      (current.errors || []).forEach(function(err) {
        const li = document.createElement("li");
        li.textContent = err;
        errorsEl.appendChild(li);
      });
    }

    const tabs = document.getElementById("import-script-tabs");
    if (tabs) {
      tabs.innerHTML = "";
      views.forEach(function(view) {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "import-script-tab is-" + (view.state || "pending");
        if (view.key === activeScriptKey) btn.classList.add("is-active");
        if (view.live) btn.classList.add("is-live");
        btn.textContent = view.live
          ? ("#" + view.iteration + " • live")
          : ("#" + view.iteration + (view.unchanged ? " =" : ""));
        btn.addEventListener("click", function() {
          activeScriptKey = view.key;
          renderScript(imp);
        });
        tabs.appendChild(btn);
      });
    }
  }

  function renderImport(data) {
    if (!data || !data.import) return;

    const imp = data.import;
    const headline = document.getElementById("import-headline");
    if (headline) headline.textContent = headlineFor(imp.status);

    updateSteps(document.getElementById("import-pipeline-main"), imp.status);
    updateSteps(document.getElementById("import-pipeline-final"), imp.status);
    updateLoop(imp.status, imp.iteration, imp.max_iterations);
    updateProgress(imp.status);
    appendEvents(imp.recent_events);
    renderScript(imp);
  }

  if (INITIAL) renderImport({ import: INITIAL });

  function poll() {
    fetch("<%= upload_status_path(@book.uid) %>")
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error_message) {
          const el = document.getElementById("import-error");
          el.style.display = "block";
          el.textContent = data.error_message;
        }
        renderImport(data);
        if (data.status === "ready" || data.status === "failed") {
          const spinner = document.getElementById("import-spinner");
          if (spinner) spinner.classList.add("is-hidden");
          if (data.status === "ready") {
            setTimeout(function() { window.location.reload(); }, 800);
          }
          return;
        }
        setTimeout(poll, 2000);
      })
      .catch(function() { setTimeout(poll, 4000); });
  }

  poll();
})();
</script>
<% end %>
