# cp env.example .env
#
# Один файл .env на локальной машине — для docker-compose и ./deploy.sh.
# На сервере (~/bookworm/.env) — отдельный файл, см. блок «Сервер» внизу.

# =============================================================================
# Приложение (локально и на сервере)
# =============================================================================

# bin/rails secret  — сгенерировать реальный ключ, не оставлять placeholder
SECRET_KEY_BASE=generate-with-bin-rails-secret

RAILS_LOG_LEVEL=info
WEB_PORT=3020

# Локально:
PUBLIC_HOST=localhost
PUBLIC_SCHEME=http
MCP_ALLOWED_ORIGINS=localhost,127.0.0.1

ELASTICSEARCH_URL=http://elasticsearch:9200
REDIS_URL=redis://redis:6379/0

# =============================================================================
# AI-импорт
# =============================================================================

AI_IMPORT_ENABLED=true
DEEPSEEK_API_KEY=sk-your-deepseek-key
PARSER_SANDBOX_IMAGE=dynamic-mcp-parser-sandbox:latest

# Путь на ХОСТЕ для mount в Docker sandbox (Sidekiq запускает parser в контейнере).
# Локально (macOS/Linux) — каталог в проекте:
BOOK_IMPORT_HOST_WORKDIR=/Users/you/projects/dynamic-mcp/tmp/book-import
# На сервере — абсолютный путь:
# BOOK_IMPORT_HOST_WORKDIR=/home/dockeruser/bookworm/tmp/book-import

# =============================================================================
# Deploy — только в локальном .env (./deploy.sh, ./logs.sh, ./restart.sh)
# =============================================================================

DEPLOY_SERVER=dockeruser@159.194.203.146
DEPLOY_PATH=/home/dockeruser/bookworm
DEPLOY_BRANCH=main

# Путь к deploy-ключу на СЕРВЕРЕ (не на Mac!) — для git pull из deploy.sh
DEPLOY_GIT_SSH_KEY=/home/dockeruser/.ssh/github_bookworm_deploy

# =============================================================================
# Nginx + HTTPS (./script/setup-nginx-remote.sh или sudo ./script/setup-nginx.sh)
# =============================================================================

BOOKWORM_DOMAIN=bookworm.breget.tech
BOOKWORM_LETSENCRYPT_EMAIL=you@example.com

# =============================================================================
# Сервер ~/bookworm/.env — отличия от локального
# =============================================================================
#
# Скопируйте env.example на сервер и замените:
#
#   PUBLIC_HOST=bookworm.breget.tech
#   PUBLIC_SCHEME=https
#   MCP_ALLOWED_ORIGINS=bookworm.breget.tech,localhost,127.0.0.1
#   BOOK_IMPORT_HOST_WORKDIR=/home/dockeruser/bookworm/tmp/book-import
#   SECRET_KEY_BASE=<свой production secret>
#   DEEPSEEK_API_KEY=sk-...
#
# DEPLOY_* на сервере не нужны (если не запускаете deploy.sh с сервера).
# Перед первым запуском: mkdir -p ~/bookworm/tmp/book-import
