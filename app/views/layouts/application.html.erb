<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <title>dynamic-mcp</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
      :root {
        --ink: #0f172a;
        --ink-soft: #334155;
        --muted: #64748b;
        --muted-light: #94a3b8;
        --line: #dbeafe;
        --line-soft: rgba(148, 163, 184, 0.35);
        --surface: #ffffff;
        --page: #f8fafc;
        --accent: #2563eb;
        --accent-2: #7c3aed;
        --ok: #059669;
        --danger: #9f1239;
        --danger-bg: linear-gradient(135deg, #fff1f2, #ffe4e6);
        --danger-border: #fecdd3;
        --card-bg: linear-gradient(160deg, #f8fafc 0%, #eef2ff 45%, #f0fdf4 100%);
        --card-shadow: 0 10px 40px rgba(15, 23, 42, 0.06);
        --radius: 16px;
        --radius-sm: 10px;
      }

      * { box-sizing: border-box; }

      body {
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
        max-width: 52rem;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
        line-height: 1.55;
        color: var(--ink);
        background:
          radial-gradient(1200px 500px at 10% -10%, rgba(99, 102, 241, 0.12), transparent 55%),
          radial-gradient(900px 420px at 100% 0%, rgba(5, 150, 105, 0.08), transparent 50%),
          var(--page);
        min-height: 100vh;
      }

      h1 {
        font-size: 1.55rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--ink);
        margin: 0 0 0.5rem;
      }

      h2 {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--muted);
        margin: 1.75rem 0 0.75rem;
      }

      p { margin: 0.5rem 0; color: var(--ink-soft); }

      a {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.15s;
      }
      a:hover { color: var(--accent-2); }

      .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.25rem;
      }

      .page-header__eyebrow {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--accent-2);
        margin-bottom: 0.35rem;
      }

      .page-header__lead {
        margin: 0;
        color: var(--muted);
        font-size: 0.95rem;
        max-width: 36rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        background: #1e293b;
        color: #f8fafc;
        white-space: nowrap;
        flex-shrink: 0;
      }

      .badge--ok { background: var(--ok); }
      .badge--soft {
        background: #e0e7ff;
        color: #3730a3;
        text-transform: none;
        letter-spacing: 0;
      }

      .card {
        margin: 1.25rem 0;
        padding: 1.25rem;
        border-radius: var(--radius);
        background: var(--card-bg);
        border: 1px solid var(--line);
        box-shadow: var(--card-shadow);
      }

      .card--solid {
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: blur(8px);
      }

      .card--dark {
        background: rgba(15, 23, 42, 0.92);
        border-color: #334155;
        color: #e2e8f0;
      }

      .card__header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .card__title {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--muted);
        margin: 0;
      }

      .card__subtitle {
        font-size: 0.9rem;
        color: var(--ink-soft);
        margin: 0.25rem 0 0;
      }

      .meta {
        color: var(--muted);
        font-size: 0.92rem;
      }

      dl.meta, dl.book-meta {
        display: grid;
        grid-template-columns: 7.5rem 1fr;
        gap: 0.45rem 0.85rem;
        margin: 0;
        padding: 0.85rem;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.55);
        border: 1px solid rgba(199, 210, 254, 0.65);
      }

      dl.meta dt, dl.book-meta dt {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
        padding-top: 0.15rem;
      }

      dl.meta dd, dl.book-meta dd {
        margin: 0;
        color: var(--ink);
        font-weight: 500;
        word-break: break-word;
      }

      .error, .flash-error {
        color: var(--danger);
        background: var(--danger-bg);
        padding: 0.85rem 1rem;
        border-radius: var(--radius-sm);
        border: 1px solid var(--danger-border);
        margin: 1rem 0;
      }

      pre {
        background: #020617;
        color: #e2e8f0;
        padding: 1rem;
        overflow-x: auto;
        border-radius: 12px;
        border: 1px solid #1e293b;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.78rem;
        line-height: 1.5;
        margin: 0.75rem 0 0;
      }

      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.86rem;
        word-break: break-all;
        background: rgba(15, 23, 42, 0.06);
        padding: 0.1rem 0.35rem;
        border-radius: 5px;
        color: #1e293b;
      }

      pre code {
        background: transparent;
        padding: 0;
        color: inherit;
        word-break: normal;
      }

      .card--dark code {
        background: rgba(148, 163, 184, 0.15);
        color: #e2e8f0;
      }

      table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin-top: 0.75rem;
        background: rgba(255, 255, 255, 0.7);
        border: 1px solid var(--line);
        border-radius: 12px;
        overflow: hidden;
      }

      th, td {
        text-align: left;
        padding: 0.7rem 0.85rem;
        border-bottom: 1px solid rgba(226, 232, 240, 0.9);
        vertical-align: top;
      }

      tr:last-child td { border-bottom: none; }

      th {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
        background: rgba(248, 250, 252, 0.9);
      }

      td strong {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .example {
        font-size: 0.8rem;
        color: var(--muted);
        margin-top: 0.35rem;
      }

      button.btn, a.btn, input.btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        padding: 0.65rem 1.35rem;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: inherit;
        border: none;
        border-radius: 999px;
        cursor: pointer;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: #fff;
        box-shadow: 0 8px 24px rgba(37, 99, 235, 0.25);
        transition: transform 0.15s, box-shadow 0.15s, filter 0.15s;
        text-decoration: none;
      }
      button.btn:hover, a.btn:hover, input.btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 12px 28px rgba(37, 99, 235, 0.32);
        filter: brightness(1.05);
        color: #fff;
      }
      button.btn:active, a.btn:active, input.btn:active { transform: translateY(0); }

      .btn--ghost {
        background: rgba(255, 255, 255, 0.7);
        color: var(--ink-soft);
        border: 1px solid var(--line);
        box-shadow: none;
      }
      a.btn.btn--ghost:hover, button.btn.btn--ghost:hover {
        color: var(--ink);
        background: #fff;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
        filter: none;
      }

      input[type=file] {
        display: block;
        width: 100%;
        margin: 0 0 1rem;
        padding: 1.25rem 1rem;
        border: 1.5px dashed #c7d2fe;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.65);
        color: var(--ink-soft);
        font-family: inherit;
        font-size: 0.9rem;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
      }
      input[type=file]:hover {
        border-color: #818cf8;
        background: #eef2ff;
        box-shadow: inset 0 0 0 1px rgba(99, 102, 241, 0.12);
      }

      .page-footer {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid var(--line-soft);
      }

      .link-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
      }

      .url-chip {
        display: block;
        margin-top: 0.5rem;
        padding: 0.65rem 0.85rem;
        border-radius: var(--radius-sm);
        background: rgba(15, 23, 42, 0.04);
        border: 1px solid rgba(148, 163, 184, 0.25);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.8rem;
        color: var(--ink-soft);
        word-break: break-all;
      }

      @media (max-width: 640px) {
        dl.meta, dl.book-meta {
          grid-template-columns: 1fr;
          gap: 0.15rem;
        }
        dl.meta dt, dl.book-meta dt { padding-top: 0.5rem; }
        dl.meta dt:first-child, dl.book-meta dt:first-child { padding-top: 0; }
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
