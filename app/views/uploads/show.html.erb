<h1>Импорт книги</h1>

<dl class="meta book-meta">
  <dt>UID</dt><dd><code><%= @book.uid %></code></dd>
  <dt>Формат</dt><dd><%= @book.source_format.upcase %></dd>
  <dt>Режим</dt><dd><%= @book_import&.mode || "—" %></dd>
</dl>

<div id="import-error" class="import-error" style="<%= @book.error_message.present? ? "" : "display:none" %>">
  <%= @book.error_message %>
</div>

<% unless @book.ready? %>
<section id="import-dashboard" class="import-dashboard<%= " is-failed" if @book.status == "failed" %>" aria-live="polite">
  <div class="import-dashboard__header">
    <div class="import-dashboard__title">
      <span class="import-spinner<%= " is-hidden" if @book.status == "failed" %>" id="import-spinner" aria-hidden="true"></span>
      <span id="import-headline"><%= @book.status == "failed" ? "Импорт не удался" : "Импорт выполняется…" %></span>
    </div>
    <div class="import-dashboard__badge" id="import-mode-badge"><%= @book_import&.mode || "ai" %></div>
  </div>

  <div class="import-progress-bar">
    <div class="import-progress-bar__fill" id="import-progress-fill" style="width: 0%"></div>
  </div>

  <ol class="import-pipeline" id="import-pipeline-main">
    <% Books::Import::Progress::PHASES.each do |phase| %>
      <li class="import-step" data-phase="<%= phase[:key] %>">
        <span class="import-step__dot"></span>
        <div class="import-step__body">
          <span class="import-step__label"><%= phase[:label] %></span>
          <span class="import-step__hint"><%= phase[:hint] %></span>
        </div>
      </li>
    <% end %>
  </ol>

  <div class="import-loop" id="import-loop">
    <div class="import-loop__header">
      <span class="import-loop__title">Цикл улучшения</span>
      <span class="import-loop__counter" id="import-iteration-label">
        итерация <%= @book_import&.iteration || 0 %> / <%= Books::Import::MAX_ITERATIONS %>
      </span>
    </div>
    <div class="import-loop__track">
      <% Books::Import::Progress::LOOP_PHASES.each do |phase| %>
        <div class="import-loop-step" data-phase="<%= phase[:key] %>">
          <span class="import-loop-step__icon"></span>
          <span class="import-loop-step__label"><%= phase[:label] %></span>
          <span class="import-loop-step__hint"><%= phase[:hint] %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="import-script-panel" id="import-script-panel" style="display:none">
    <div class="import-script-panel__header">
      <div>
        <div class="import-script-panel__title">Ruby-парсер</div>
        <div class="import-script-panel__subtitle" id="import-script-subtitle">ожидание…</div>
      </div>
      <span class="import-script-badge" id="import-script-badge">—</span>
    </div>
    <div class="import-script-tabs" id="import-script-tabs"></div>
    <div class="import-script-viewport" id="import-script-viewport">
      <pre class="import-script-code" id="import-script-code"><code></code></pre>
    </div>
    <ul class="import-script-errors" id="import-script-errors"></ul>
  </div>

  <ol class="import-pipeline import-pipeline--final" id="import-pipeline-final">
    <% Books::Import::Progress::FINAL_PHASES.each do |phase| %>
      <li class="import-step" data-phase="<%= phase[:key] %>">
        <span class="import-step__dot"></span>
        <div class="import-step__body">
          <span class="import-step__label"><%= phase[:label] %></span>
          <span class="import-step__hint"><%= phase[:hint] %></span>
        </div>
      </li>
    <% end %>
  </ol>

  <div class="import-log" id="import-log">
    <div class="import-log__title">Журнал</div>
    <ul class="import-log__list" id="import-log-list"></ul>
  </div>
</section>
<% end %>

<% if @book.ready? %>
<div id="book-ready">
  <dl class="meta">
    <dt>Название</dt><dd id="book-title"><%= @book.title %></dd>
    <dt>Автор</dt><dd id="book-author"><%= @book.author.presence || "—" %></dd>
    <dt>Страниц</dt><dd id="book-pages"><%= @book.page_count %></dd>
  </dl>

  <h2>MCP для ИИ-агента</h2>
  <p>
    <%= link_to "Документация MCP →", book_mcp_path(@book.uid) %>
  </p>
  <p class="meta"><code><%= @mcp_doc_url %></code></p>

  <h2>REST API</h2>
  <p class="meta">Базовый URL: <code><%= request.base_url %></code></p>

  <table>
    <thead>
      <tr>
        <th>Метод</th>
        <th>URL</th>
        <th>Описание</th>
      </tr>
    </thead>
    <tbody>
      <% @endpoints.each do |ep| %>
        <tr>
          <td><strong><%= ep.method %></strong></td>
          <td>
            <code><%= ep.path %></code>
            <% if ep.example.present? && ep.example != ep.path %>
              <div class="example">Пример: <code><%= ep.example %></code></div>
            <% end %>
          </td>
          <td><%= ep.description %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% else %>
<div id="book-ready" style="display:none"></div>
<% end %>

<p><%= link_to "Загрузить другую книгу", root_path %></p>

<style>
  .import-dashboard.is-failed {
    background: linear-gradient(160deg, #fff1f2 0%, #fef2f2 100%);
    border-color: #fecdd3;
  }

  .import-error {
